# Formatting for the library's own code (src/, include/, tests/, examples/).
# The vendored CoppeliaSim remote API under lib/ is third-party and is not
# formatted (CI only checks the directories listed above).
---
Language: Cpp
Standard: c++20

# Existing style: tab indentation, Allman braces, indented namespace contents,
# continuation lines indented one extra tab (not aligned to the open paren).
UseTab: ForContinuationAndIndentation
IndentWidth: 4
TabWidth: 4
ContinuationIndentWidth: 4
AlignAfterOpenBracket: DontAlign
BreakBeforeBraces: Allman
NamespaceIndentation: All
AccessModifierOffset: -4

PointerAlignment: Left
ReferenceAlignment: Left

# Keep the authors' manual line breaks; only fix indentation/spacing.
ColumnLimit: 0

# Include order is deliberate (extern "C" block order matters for the C API).
SortIncludes: Never

AllowShortFunctionsOnASingleLine: All
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortLambdasOnASingleLine: All
IndentCaseLabels: false
FixNamespaceComments: false
SpaceAfterTemplateKeyword: false
